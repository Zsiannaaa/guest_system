Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct browser access to internal application folders.
    RewriteRule ^(config|includes|modules|db_backups|docs|tools)(/|$) - [F,L]
    RewriteRule (^|/)\. - [F,L]

    # Keep direct access to existing files and directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all other requests to index.php.
    RewriteRule ^ index.php [L]
</IfModule>

# Basic hardening for private/generated files.
<FilesMatch "^(hostingcredentials\.txt|database\.sql|migration_gh\.sql)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.(env|gitignore|htaccess)$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|md|py)$">
    Require all denied
</FilesMatch>
